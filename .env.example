# Variables de entorno para Django + Render + Neon

# DEBUG: Cambiar a False en producción
DEBUG=False

# SECRET_KEY: Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-clave-secreta-super-segura

# DATABASE - para Neon (reemplaza con tu URL)
DATABASE_URL=postgresql://usuario:contraseña@host.neon.tech/basedatos?sslmode=require&channel_binding=require

# ALLOWED_HOSTS: Dominios permitidos
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1

# CORS: Dominios frontend permitidos
CORS_ALLOWED_ORIGINS=https://tu-frontend.onrender.com,http://localhost:5173

# CSRF: Dominios CSRF de confianza
CSRF_TRUSTED_ORIGINS=https://tu-frontend.onrender.com,http://localhost:5173

# Variables locales (ignorar si usas DATABASE_URL)
DB_NAME=indapmuni
DB_USER=postgres
DB_PASSWORD=tu-contraseña
DB_HOST=localhost
DB_PORT=5432
